# ==========================================================
# DeepShield - .gitignore
# ==========================================================

##############################
# Python
##############################
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

##############################
# Virtual Environment
##############################
denv/
venv/
env/
ENV/
.venv/

##############################
# Jupyter Notebook
##############################
.ipynb_checkpoints/

##############################
# Python Build
##############################
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

##############################
# Logs
##############################
logs/
*.log

##############################
# Environment Variables
##############################
.env
.env.local
.env.development
.env.production
.env.test

##############################
# VS Code
##############################
.vscode/
.history/

##############################
# PyCharm
##############################
.idea/

##############################
# OS Files
##############################
.DS_Store
Thumbs.db
desktop.ini

##############################
# Node.js
##############################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-lock.yaml

##############################
# Next.js
##############################
.next/
out/

##############################
# React Build
##############################
build/

##############################
# Coverage
##############################
.coverage
coverage/
htmlcov/
.pytest_cache/

##############################
# Model Checkpoints
##############################
*.ckpt
*.pt
*.pth
*.h5
*.keras
*.onnx
*.tflite

##############################
# AI Model Cache
##############################
.cache/
.huggingface/
transformers_cache/

##############################
# Dataset Cache
##############################
*.cache

##############################
# Uploaded Files
##############################
uploads/
temp/
tmp/

##############################
# TensorBoard
##############################
runs/
events.out.tfevents.*

##############################
# FFmpeg Temporary Files
##############################
*.tmp
*.temp

##############################
# MongoDB Dumps
##############################
dump/

##############################
# Docker
##############################
*.pid

##############################
# Runtime
##############################
*.sqlite3
*.db

##############################
# Secrets
##############################
*.pem
*.key
*.crt
*.p12

##############################
# Archives
##############################
*.zip
*.rar
*.7z
*.tar
*.gz

##############################
# Media Generated During Testing
##############################
test_outputs/
predictions/
reports/
screenshots/

##############################
# Mac/Linux Temporary Files
##############################
*~
*.swp
*.swo

backend/temp_uploads/

##############################
# Ignore Large Datasets
##############################
datasets/